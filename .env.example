# WHITE-HAT-STOAT Environment Variables
# Copy to .env and modify as needed

# Application
STOAT_ENVIRONMENT=production
STOAT_LOG_LEVEL=INFO
STOAT_DEBUG=false

# Directories
STOAT_HOME=/opt/white-hat-stoat
STOAT_DATA=/var/lib/white-hat-stoat
STOAT_LOG=/var/log/white-hat-stoat
STOAT_CONFIG=/etc/white-hat-stoat

# Database
STOAT_DB_TYPE=sqlite
STOAT_DB_PATH=${STOAT_DATA}/stoat.db
# For PostgreSQL:
# STOAT_DB_TYPE=postgresql
# STOAT_DB_HOST=postgres
# STOAT_DB_PORT=5432
# STOAT_DB_NAME=stoat
# STOAT_DB_USER=stoat
# STOAT_DB_PASSWORD=stoat2024

# Redis (for caching and messaging)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=stoat2024

# Web Dashboard
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_SECRET_KEY=your_secret_key_here

# Platform Integration
# Discord
DISCORD_ENABLED=false
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_channel_id

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_CHANNEL_ID=your_channel_id

# Keylogger
KEYLOGGER_ENABLED=true
KEYLOGGER_PORT=4444
KEYLOGGER_INTERVAL=30

# Payload Generation
PAYLOAD_CALLBACK_HOST=localhost
PAYLOAD_CALLBACK_PORT=5555
PAYLOAD_DEFAULT_PORT=4444

# Security
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here